{
  "productName": "Dotit",
  "version": "1.0.0",
  "identifier": "io.dotit.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Dotit",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "publisher": "Dotit Labs",
    "shortDescription": "Dotit is a native desktop editor for .it documents.",
    "longDescription": "Dotit is a professional desktop app for authoring, validating, searching, and running workflows on .it documents with local-first vault support.",
    "fileAssociations": [
      {
        "ext": [
          "it"
        ],
        "name": "Dotit Document"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "dialog": null,
    "fs": null,
    "window-state": null
  }
}